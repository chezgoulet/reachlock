{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Charted System (S21)",
  "description": "An authored charted system in the gate network.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "display_name", "position", "biome", "seed", "description"],
  "properties": {
    "id": { "type": "string", "description": "Unique system id; matches gate network node ids" },
    "display_name": { "type": "string", "description": "Human-readable name" },
    "position": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "z"],
      "properties": {
        "x": { "type": "integer", "description": "Galactic X coordinate" },
        "y": { "type": "integer", "description": "Galactic Y coordinate" },
        "z": { "type": "integer", "description": "Galactic Z coordinate" }
      }
    },
    "biome": {
      "type": "string",
      "enum": ["core", "frontier", "nebula", "derelict", "deep_space"]
    },
    "seed": { "type": "integer", "minimum": 0, "maximum": 9007199254740991, "description": "System generator seed (≤ 2^53)" },
    "description": { "type": "string", "description": "In-fiction system description" }
  }
}
