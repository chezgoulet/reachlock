{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Planet Culture Content File",
  "description": "An authored planet culture override",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "display_name", "asset_type", "seed", "universe", "priority", "payload"],
  "properties": {
    "id": { "type": "string" },
    "display_name": { "type": "string" },
    "asset_type": { "type": "string", "enum": ["planet_culture"] },
    "seed": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
    "universe": { "type": "string" },
    "priority": { "type": "string", "enum": ["procedural", "curated", "event", "authoritative"] },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["planet_culture"],
      "properties": {
        "planet_culture": { "type": "object" }
      }
    }
  }
}
