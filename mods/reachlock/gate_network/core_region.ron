GateNetwork(
    gates: [
        // Aethon — the Compact's seat — is the hub of the core region.
        // Three gates out to the inner frontier; all active.
        (from: "aethon", to: "verne", status: Active),
        (from: "aethon", to: "cadence", status: Active),
        (from: "aethon", to: "sorrow", status: Active),
        // Verne — a research outpost on the veil's edge.
        (from: "verne", to: "cadence", status: Active),
        (from: "verne", to: "the_veil", status: Restricted, controlled_by: "compact"),
        // Cadence — trade hub, connects to the fringe.
        (from: "cadence", to: "sorrow", status: Active),
        (from: "cadence", to: "fringe_a", status: Active),
        // Sorrow — the fall: a once-thriving colony system, now derelict.
        // Blockaded by the Earth Remnant.
        (from: "sorrow", to: "earth", status: Blockaded, controlled_by: "earth_remnant"),
        (from: "sorrow", to: "fringe_b", status: Active),
        // Earth — homeworld, lost. The Remnant holds the gate shut.
        (from: "earth", to: "fringe_b", status: Blockaded, controlled_by: "earth_remnant"),
        // The Veil — a nebula system, Compact scientific expedition.
        (from: "the_veil", to: "fringe_a", status: Active),
        (from: "the_veil", to: "fringe_b", status: Active),
        // Fringe systems — the frontier edge.
        (from: "fringe_a", to: "fringe_b", status: Active),
        (from: "fringe_b", to: "fringe_a", status: Active),
    ],
)
