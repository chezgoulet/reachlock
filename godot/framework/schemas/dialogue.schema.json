{
  "$id": "reachlock://framework/v0/dialogue",
  "title": "Dialogue graph",
  "description": "An authored conversation with an NPC. Nodes are NPC turns: `authored` nodes carry fixed text; `generated` nodes carry a prompt_hint that becomes the perceive objective for the soul's mind (Pan), so authored structure and LLM improvisation interleave in one graph. Choices are player turns; their conditions are trigger-DSL strings (validated in CI) and their mutations are the soul-mutation vocabulary. `goto: \"end\"` closes the conversation.",
  "type": "object",
  "required": ["id", "npc", "entry", "nodes"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
    "npc": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
    "entry": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
    "condition": { "type": "string", "description": "Trigger-DSL guard: when this dialogue is available at all." },
    "nodes": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["kind"],
        "additionalProperties": false,
        "properties": {
          "kind": { "enum": ["authored", "generated"] },
          "text": { "type": "string", "description": "authored only: the NPC line, verbatim." },
          "prompt_hint": { "type": "string", "description": "generated only: becomes the perceive goal objective; the soul improvises the line." },
          "mutations": { "type": "array", "items": { "$ref": "#/$defs/mutation" } },
          "goto": { "type": "string", "description": "Next node when there are no choices. \"end\" closes." },
          "choices": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["text", "goto"],
              "additionalProperties": false,
              "properties": {
                "text": { "type": "string" },
                "condition": { "type": "string", "description": "Trigger-DSL: choice shown only when true." },
                "goto": { "type": "string" },
                "mutations": { "type": "array", "items": { "$ref": "#/$defs/mutation" } }
              }
            }
          }
        }
      }
    },
    "extra": { "type": "object" }
  },
  "$defs": {
    "mutation": {
      "oneOf": [
        {
          "type": "object",
          "required": ["op", "target", "axis", "amount"],
          "additionalProperties": false,
          "properties": {
            "op": { "const": "adjust_relationship" },
            "target": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
            "axis": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
            "amount": { "type": "integer", "minimum": -100, "maximum": 100 }
          }
        },
        {
          "type": "object",
          "required": ["op", "text"],
          "additionalProperties": false,
          "properties": {
            "op": { "const": "add_memory" },
            "text": { "type": "string" },
            "importance": { "type": "number", "minimum": 0, "maximum": 1 },
            "tags": { "type": "array", "items": { "type": "string" } }
          }
        },
        {
          "type": "object",
          "required": ["op", "flag"],
          "additionalProperties": false,
          "properties": {
            "op": { "const": "set_flag" },
            "flag": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" }
          }
        },
        {
          "type": "object",
          "required": ["op", "flag"],
          "additionalProperties": false,
          "properties": {
            "op": { "const": "clear_flag" },
            "flag": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" }
          }
        }
      ]
    }
  }
}
