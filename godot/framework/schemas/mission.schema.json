{
  "$id": "reachlock://framework/v0/mission",
  "title": "Authored mission definition",
  "description": "A mission is an ordered sequence of stages. Each stage has a type, trigger, objective, completion criteria, failure conditions, and rewards. Data-driven — modders author missions as JSON files. The engine never names a mission id.",
  "type": "object",
  "required": ["id", "name", "stages"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "visible": { "type": "boolean", "default": true },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "objective"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "type": {
            "type": "string",
            "enum": ["waypoint", "dialogue", "combat", "timer", "delivery", "landing", "jump", "dock", "undock", "custom"]
          },
          "objective": { "type": "string", "description": "Text shown to player as current objective." },
          "trigger": {
            "type": "object",
            "description": "Condition for this stage to become active. Omitted = activates when previous stage completes.",
            "properties": {
              "condition": { "type": "string", "description": "Trigger-DSL condition. Stage activates when true." },
              "delay_seconds": { "type": "number", "minimum": 0 }
            }
          },
          "completion": {
            "type": "object",
            "description": "What makes this stage succeed. Omitted = manual advance via trigger.",
            "properties": {
              "type": {
                "type": "string",
                "enum": ["arrive", "dialogue_end", "kill_all", "timer", "deliver", "dock", "undock", "jump", "event", "manual"]
              },
              "target_id": { "type": "string", "description": "Location ID, NPC ID, good ID, or event name depending on type." },
              "count": { "type": "integer", "minimum": 1, "description": "How many (kills, deliveries, event occurrences, etc.)" }
            }
          },
          "failure": {
            "type": "object",
            "description": "Conditions that cause mission failure. Omitted = no stage-specific failure.",
            "properties": {
              "timer_seconds": { "type": "number", "minimum": 0, "description": "Stage must complete within this time." },
              "on_death": { "type": "boolean", "default": true },
              "on_ship_destroyed": { "type": "boolean", "default": true }
            }
          },
          "rewards": {
            "type": "object",
            "description": "Rewards granted when this stage completes.",
            "properties": {
              "credits": { "type": "integer", "minimum": 0 },
              "cargo": {
                "type": "object",
                "description": "good id -> qty loaded into the player's hold (a mission handing you its McGuffin).",
                "additionalProperties": { "type": "integer" }
              },
              "faction_deltas": {
                "type": "object",
                "additionalProperties": {
                  "type": "object",
                  "additionalProperties": { "type": "integer", "minimum": -100, "maximum": 100 }
                }
              },
              "soul_mutations": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "npc": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
                    "op": { "enum": ["add_memory", "adjust_relationship", "set_flag", "clear_flag"] },
                    "text": { "type": "string" },
                    "target": { "type": "string" },
                    "axis": { "type": "string" },
                    "amount": { "type": "integer", "minimum": -100, "maximum": 100 },
                    "flag": { "type": "string" },
                    "importance": { "type": "number", "minimum": 0, "maximum": 1 },
                    "tags": { "type": "array", "items": { "type": "string" } }
                  }
                }
              }
            }
          }
        }
      }
    },
    "failure_global": {
      "type": "object",
      "description": "Global failure conditions for the entire mission.",
      "properties": {
        "on_death": { "type": "boolean", "default": true },
        "on_ship_destroyed": { "type": "boolean", "default": true }
      }
    },
    "next": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "Mission id to start automatically when this one completes. Data-driven chaining — an authored campaign is a linked list of missions; the engine never names one."
    },
    "epilogue": {
      "type": "object",
      "description": "Full-screen cards shown when the mission ends. `success` shows on completion, `failure` on any failure (a per-reason override wins when `failure_reasons` has a matching key). Shown by the framework MissionHud.",
      "additionalProperties": false,
      "properties": {
        "success": { "type": "string" },
        "failure": { "type": "string" },
        "failure_reasons": {
          "type": "object",
          "description": "failure reason keyword -> epilogue text override (e.g. ship_destroyed, time_expired).",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "rewards_final": {
      "type": "object",
      "description": "Final rewards granted on mission completion (all stages done).",
      "properties": {
        "credits": { "type": "integer", "minimum": 0 },
        "faction_deltas": { "type": "object" },
        "soul_mutations": { "type": "array", "items": { "type": "object" } }
      }
    },
    "extra": { "type": "object", "description": "Free-form escape hatch." }
  }
}
