; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="REACHLOCK"
config/description="A game about surviving the frontier, choosing your allegiances, and living with the consequences of a universe that doesn't wait for you."
config/version="0.1.0"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.7", "GL Compatibility")
config/icon="res://assets/ui/icon.svg"

[autoload]

DataRegistry="*res://scripts/framework/data_registry.gd"
AssetLibrary="*res://scripts/framework/asset_library.gd"
GameState="*res://scripts/framework/game_state.gd"
MemoryStore="*res://scripts/framework/memory_store.gd"
SoulGateway="*res://scripts/framework/soul_gateway.gd"
SimGateway="*res://scripts/framework/sim_gateway.gd"
CrewRoster="*res://scripts/framework/crew_roster.gd"
ShipOperation="*res://scripts/framework/ship_operation.gd"
MissionManager="*res://scripts/framework/mission_manager.gd"
MissionHud="*res://scripts/framework/mission_hud.gd"
GravitySystem="*res://scripts/framework/gravity_system.gd"
AudioManager="*res://scripts/framework/audio_manager.gd"
Reputation="*res://scripts/framework/reputation_manager.gd"
GameManager="*res://scripts/game_manager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
