{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Hull Content File",
  "description": "A hull is a mesh defining the exterior of a ship",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "display_name", "asset_type", "seed", "universe", "priority", "payload"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for this hull"
    },
    "display_name": {
      "type": "string",
      "description": "Human-readable name for display in the UI"
    },
    "asset_type": {
      "type": "string",
      "enum": ["hull"],
      "description": "Must be 'hull' for this schema"
    },
    "seed": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991,
      "description": "Canonical seed (hash of content_override, system_id, object_id)"
    },
    "universe": {
      "type": "string",
      "description": "'all' or a universe tier name (classic, fair_play, spectrum, byok)"
    },
    "priority": {
      "type": "string",
      "enum": ["procedural", "curated", "event", "authoritative"],
      "description": "Priority level for this content"
    },
    "expires_at": {
      "type": "integer",
      "description": "Optional expiration timestamp (only meaningful when priority is 'event')"
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hull"],
      "properties": {
        "hull": {
          "type": "object",
          "additionalProperties": false,
          "required": ["vertices", "indices"],
          "properties": {
            "vertices": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["x", "y"],
                "properties": {
                  "x": {
                    "type": "integer",
                    "description": "X coordinate (fixed-point i64)"
                  },
                  "y": {
                    "type": "integer",
                    "description": "Y coordinate (fixed-point i64)"
                  }
                }
              },
              "description": "Array of vertices"
            },
            "indices": {
              "type": "array",
              "items": {
                "type": "integer",
                "minimum": 0
              },
              "description": "Triangle indices into the vertices array"
            }
          }
        }
      }
    }
  }
}
