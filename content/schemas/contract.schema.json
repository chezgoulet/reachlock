{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Contract Content File",
  "description": "A contract is player-authored automation for a ship system or crew member",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "display_name", "asset_type", "seed", "universe", "priority", "payload"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for this contract"
    },
    "display_name": {
      "type": "string",
      "description": "Human-readable name for display in the UI"
    },
    "asset_type": {
      "type": "string",
      "enum": ["contract"],
      "description": "Must be 'contract' for this schema"
    },
    "seed": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991,
      "description": "Canonical seed (hash of content_override, system_id, object_id)"
    },
    "universe": {
      "type": "string",
      "description": "'all' or a universe tier name (classic, fair_play, spectrum, byok)"
    },
    "priority": {
      "type": "string",
      "enum": ["procedural", "curated", "event", "authoritative"],
      "description": "Priority level for this content"
    },
    "expires_at": {
      "type": "integer",
      "description": "Optional expiration timestamp (only meaningful when priority is 'event')"
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contract"],
      "properties": {
        "contract": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "label", "trigger", "rules"],
          "properties": {
            "id": {
              "type": "string",
              "description": "Unique identifier for this contract"
            },
            "label": {
              "type": "string",
              "description": "Human-readable label for this contract"
            },
            "trigger": {
              "oneOf": [
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["Timer"],
                  "properties": {
                    "Timer": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["interval_secs", "repeat"],
                      "properties": {
                        "interval_secs": {
                          "type": "integer",
                          "minimum": 0
                        },
                        "repeat": {
                          "type": "boolean"
                        }
                      }
                    }
                  }
                },
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["Event"],
                  "properties": {
                    "Event": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["event_type"],
                      "properties": {
                        "event_type": {
                          "type": "string"
                        }
                      }
                    }
                  }
                },
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["StateChange"],
                  "properties": {
                    "StateChange": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["field", "op", "value"],
                      "properties": {
                        "field": {
                          "type": "string"
                        },
                        "op": {
                          "type": "string",
                          "enum": ["lt", "le", "eq", "ne", "ge", "gt"]
                        },
                        "value": {
                          "type": "integer"
                        }
                      }
                    }
                  }
                },
                {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "Manual": {}
                  }
                }
              ]
            },
            "rules": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["condition", "action"],
                "properties": {
                  "condition": {
                    "$ref": "#/definitions/Condition"
                  },
                  "action": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["kind"],
                    "properties": {
                      "kind": {
                        "type": "string"
                      },
                      "params": {
                        "type": "object",
                        "additionalProperties": {
                          "type": "integer"
                        }
                      }
                    }
                  },
                  "priority": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 255
                  }
                }
              }
            },
            "llm_authority": {
              "type": "object",
              "additionalProperties": false,
              "required": ["fallback_on_timeout", "timeout_ms", "max_tokens", "system_prompt"],
              "properties": {
                "fallback_on_timeout": {
                  "type": "boolean"
                },
                "timeout_ms": {
                  "type": "integer",
                  "minimum": 0
                },
                "max_tokens": {
                  "type": "integer",
                  "minimum": 0
                },
                "system_prompt": {
                  "type": "string"
                },
                "fallback_action": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["kind"],
                  "properties": {
                    "kind": {
                      "type": "string"
                    },
                    "params": {
                      "type": "object",
                      "additionalProperties": {
                        "type": "integer"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "definitions": {
    "Condition": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "Always": {}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["Compare"],
          "properties": {
            "Compare": {
              "type": "object",
              "additionalProperties": false,
              "required": ["field", "op", "value"],
              "properties": {
                "field": {
                  "type": "string"
                },
                "op": {
                  "type": "string",
                  "enum": ["lt", "le", "eq", "ne", "ge", "gt"]
                },
                "value": {
                  "type": "integer"
                }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["Not"],
          "properties": {
            "Not": {
              "$ref": "#/definitions/Condition"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["All"],
          "properties": {
            "All": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/Condition"
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["Any"],
          "properties": {
            "Any": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/Condition"
              }
            }
          }
        }
      ]
    }
  }
}
