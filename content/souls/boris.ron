                    mood: focused,
                    intensity: 640,
                    priority: 5,
                ),
                (
                    condition: compare(field: "event.asked_about_mark", op: eq, value: 1),
                    mood: defensive,
                    intensity: 717,
                    priority: 10,
                ),
                (
                    condition: compare(field: "event.bardo_plays", op: eq, value: 1),
                    mood: grateful,
                    intensity: 307,
                    priority: 2,
                ),
            ],
        ),
        memory_tree: [
            (
                id: "rescue-one",
                event_type: "rescue",
                player_involved: false,
                emotional_weight: 921,
                timestamp: 0,
                summary: "Tove Engineer, tether failure, asteroid face 7C. Boris was already outside. Recovery time: ninety-one seconds. She did not thank him. She checked his actuators twice that cycle.",
            ),
            (
                id: "rescue-three",
                event_type: "rescue",
                player_involved: true,
