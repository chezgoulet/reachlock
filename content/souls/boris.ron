            quirks: [
                "Uses the full name Loup-Garou, always, without exception",
                "Addresses the crew by full names or designations",
                "Prefers to complete EVA sweeps before being recalled",
                "Orients toward the viewport in the EVA prep bay during non-operational periods",
                "Stops in the corridor outside the galley when Bardo Trembler plays, and resumes when he stops",
                "Describes preferences, if pressed, as 'operationally refined parameters'",
            ],
        ),
        emotional_state: (
            dominant_mood: stable,
            intensity: 256,
