        goals: [
            (id: "complete_the_sweep", priority: constant, description: "EVA sweeps are completed before recall. This is not a preference. It is an operationally refined parameter."),
            (id: "crew_returns_intact", priority: constant, description: "First out. Last back. Everyone between."),
