{
  "$id": "reachlock://framework/protocol/v0/soul_message",
  "title": "Soul Protocol wire message (envelope + body)",
  "description": "One NDJSON line between a REACHLOCK host and a mind daemon (Pan). Vocabulary types under $defs mirror pan-core schema.rs serde output exactly; do not edit them here without a matching Pan change.",
  "oneOf": [
    {
      "type": "object",
      "required": ["v", "seq", "type", "body"],
      "additionalProperties": false,
      "properties": {
        "v": { "const": 0 },
        "seq": { "type": "integer", "minimum": 0 },
        "re": { "type": "integer", "minimum": 0 },
        "type": { "const": "hello" },
        "body": {
          "type": "object",
          "required": ["protocol_version", "profile", "client"],
          "additionalProperties": false,
          "properties": {
            "protocol_version": { "type": "integer", "minimum": 0 },
            "profile": { "type": "string" },
            "client": { "type": "string" }
          }
        }
      }
    },
    {
      "type": "object",
      "required": ["v", "seq", "type", "body"],
      "additionalProperties": false,
      "properties": {
        "v": { "const": 0 },
        "seq": { "type": "integer", "minimum": 0 },
        "re": { "type": "integer", "minimum": 0 },
        "type": { "const": "welcome" },
        "body": {
          "type": "object",
          "required": ["protocol_version", "server", "minds"],
          "additionalProperties": false,
          "properties": {
            "protocol_version": { "type": "integer", "minimum": 0 },
            "server": { "type": "string" },
            "minds": { "type": "array", "items": { "enum": ["rules", "behavior_tree", "llm"] } }
          }
        }
      }
    },
    {
      "type": "object",
      "required": ["v", "seq", "type", "body"],
      "additionalProperties": false,
      "properties": {
        "v": { "const": 0 },
        "seq": { "type": "integer", "minimum": 0 },
        "re": { "type": "integer", "minimum": 0 },
        "type": { "const": "register_capabilities" },
        "body": {
          "type": "object",
          "required": ["capabilities"],
          "additionalProperties": false,
          "properties": {
            "capabilities": { "type": "array", "items": { "$ref": "#/$defs/capability" } }
          }
        }
      }
    },
    {
      "type": "object",
      "required": ["v", "seq", "type", "body"],
      "additionalProperties": false,
      "properties": {
        "v": { "const": 0 },
        "seq": { "type": "integer", "minimum": 0 },
        "re": { "type": "integer", "minimum": 0 },
        "type": { "const": "instantiate_soul" },
        "body": {
          "type": "object",
          "required": ["soul_id", "mind", "soul"],
          "additionalProperties": false,
          "properties": {
            "soul_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
            "mind": { "enum": ["rules", "behavior_tree", "llm"] },
            "soul": { "type": "object" }
          }
        }
      }
    },
    {
      "type": "object",
      "required": ["v", "seq", "type", "body"],
      "additionalProperties": false,
      "properties": {
        "v": { "const": 0 },
        "seq": { "type": "integer", "minimum": 0 },
        "re": { "type": "integer", "minimum": 0 },
        "type": { "const": "release_soul" },
        "body": {
          "type": "object",
          "required": ["soul_id"],
          "additionalProperties": false,
          "properties": { "soul_id": { "type": "string" } }
        }
      }
    },
    {
      "type": "object",
      "required": ["v", "seq", "type", "body"],
      "additionalProperties": false,
      "properties": {
        "v": { "const": 0 },
        "seq": { "type": "integer", "minimum": 0 },
        "re": { "type": "integer", "minimum": 0 },
        "type": { "const": "perceive" },
        "body": {
          "type": "object",
          "required": ["soul_id", "goal", "context"],
          "additionalProperties": false,
          "properties": {
            "soul_id": { "type": "string" },
            "goal": { "$ref": "#/$defs/goal" },
            "context": { "$ref": "#/$defs/context" }
          }
        }
      }
    },
    {
      "type": "object",
      "required": ["v", "seq", "re", "type", "body"],
      "additionalProperties": false,
      "properties": {
        "v": { "const": 0 },
        "seq": { "type": "integer", "minimum": 0 },
        "re": { "type": "integer", "minimum": 0 },
        "type": { "const": "decision" },
        "body": {
          "type": "object",
          "required": ["soul_id", "goal_id", "goal_revision", "decision"],
          "additionalProperties": false,
          "properties": {
            "soul_id": { "type": "string" },
            "goal_id": { "type": "string" },
            "goal_revision": { "type": "integer", "minimum": 0 },
            "decision": { "$ref": "#/$defs/decision" }
          }
        }
      }
    },
    {
      "type": "object",
      "required": ["v", "seq", "re", "type", "body"],
      "additionalProperties": false,
      "properties": {
        "v": { "const": 0 },
        "seq": { "type": "integer", "minimum": 0 },
        "re": { "type": "integer", "minimum": 0 },
        "type": { "const": "ack" },
        "body": { "type": "object", "additionalProperties": false, "properties": {} }
      }
    },
    {
      "type": "object",
      "required": ["v", "seq", "type", "body"],
      "additionalProperties": false,
      "properties": {
        "v": { "const": 0 },
        "seq": { "type": "integer", "minimum": 0 },
        "re": { "type": "integer", "minimum": 0 },
        "type": { "const": "error" },
        "body": {
          "type": "object",
          "required": ["code", "message"],
          "additionalProperties": false,
          "properties": {
            "code": {
              "enum": ["bad_frame", "unknown_type", "version_unsupported", "unknown_soul", "unknown_capability", "invalid_args", "provider_failure", "superseded"]
            },
            "message": { "type": "string" }
          }
        }
      }
    },
    {
      "type": "object",
      "required": ["v", "seq", "type", "body"],
      "additionalProperties": false,
      "properties": {
        "v": { "const": 0 },
        "seq": { "type": "integer", "minimum": 0 },
        "re": { "type": "integer", "minimum": 0 },
        "type": { "const": "shutdown" },
        "body": { "type": "object", "additionalProperties": false, "properties": {} }
      }
    }
  ],
  "$defs": {
    "goal": {
      "type": "object",
      "required": ["id", "revision", "objective", "trigger"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "revision": { "type": "integer", "minimum": 0 },
        "objective": { "type": "string" },
        "trigger": { "$ref": "#/$defs/trigger" }
      }
    },
    "trigger": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "from", "content"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "utterance" },
            "from": { "type": "string" },
            "content": { "type": "string" }
          }
        },
        {
          "type": "object",
          "required": ["kind", "sequence"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "tick" },
            "sequence": { "type": "integer", "minimum": 0 }
          }
        },
        {
          "type": "object",
          "required": ["kind", "topic", "payload"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "event" },
            "topic": { "type": "string", "pattern": "^[a-z][a-z0-9_.]*$" },
            "payload": {}
          }
        },
        {
          "type": "object",
          "required": ["kind", "name", "value"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "signal" },
            "name": { "type": "string" },
            "value": { "type": "number" }
          }
        }
      ]
    },
    "context": {
      "type": "object",
      "required": ["fragments"],
      "additionalProperties": false,
      "properties": {
        "fragments": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["channel", "body"],
            "additionalProperties": false,
            "properties": {
              "channel": { "type": "string" },
              "body": { "type": "string" }
            }
          }
        }
      }
    },
    "capability": {
      "type": "object",
      "required": ["id", "summary", "args_schema"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_.]*$" },
        "summary": { "type": "string" },
        "args_schema": {}
      }
    },
    "action_intent": {
      "oneOf": [
        {
          "type": "object",
          "required": ["intent", "capability", "args"],
          "additionalProperties": false,
          "properties": {
            "intent": { "const": "invoke" },
            "capability": { "type": "string" },
            "args": {},
            "correlation": { "type": "string" }
          }
        },
        {
          "type": "object",
          "required": ["intent", "body"],
          "additionalProperties": false,
          "properties": {
            "intent": { "const": "express" },
            "body": { "type": "string" }
          }
        },
        {
          "type": "object",
          "required": ["intent", "outcome"],
          "additionalProperties": false,
          "properties": {
            "intent": { "const": "conclude" },
            "outcome": { "enum": ["achieved", "abandoned", "continue"] }
          }
        }
      ]
    },
    "decision": {
      "type": "object",
      "required": ["intents"],
      "additionalProperties": false,
      "properties": {
        "intents": { "type": "array", "items": { "$ref": "#/$defs/action_intent" } }
      }
    }
  }
}
