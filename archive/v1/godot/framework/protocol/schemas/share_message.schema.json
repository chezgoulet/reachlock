{
  "$id": "reachlock://framework/protocol/v0/share_message",
  "title": "Ship-Share payload (kind + body)",
  "description": "One Ship-Share payload dictionary (SHIP-SHARE.md), in its JSON form. These ride Godot's high-level ENet RPC as Dictionaries; the schema pins their shapes so host and client builds can only drift loudly. Clients send intents; the host sends state.",
  "oneOf": [
    {
      "type": "object",
      "required": ["kind", "body"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "hello" },
        "body": {
          "type": "object",
          "required": ["share_version", "game_version", "name"],
          "additionalProperties": false,
          "properties": {
            "share_version": { "type": "integer", "minimum": 0 },
            "game_version": { "type": "string" },
            "name": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    {
      "type": "object",
      "required": ["kind", "body"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "welcome" },
        "body": {
          "type": "object",
          "required": ["share_version", "roster", "seats"],
          "additionalProperties": false,
          "properties": {
            "share_version": { "type": "integer", "minimum": 0 },
            "roster": { "$ref": "#/$defs/roster" },
            "seats": { "$ref": "#/$defs/seats" }
          }
        }
      }
    },
    {
      "type": "object",
      "required": ["kind", "body"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "refuse" },
        "body": {
          "type": "object",
          "required": ["reason", "host_version", "yours"],
          "additionalProperties": false,
          "properties": {
            "reason": { "enum": ["version_mismatch", "full", "not_hosting"] },
            "host_version": { "type": "integer", "minimum": 0 },
            "yours": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    {
      "type": "object",
      "required": ["kind", "body"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "claim_seat" },
        "body": {
          "type": "object",
          "required": ["npc_id"],
          "additionalProperties": false,
          "properties": { "npc_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" } }
        }
      }
    },
    {
      "type": "object",
      "required": ["kind", "body"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "release_seat" },
        "body": { "type": "object", "additionalProperties": false, "properties": {} }
      }
    },
    {
      "type": "object",
      "required": ["kind", "body"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "seat_denied" },
        "body": {
          "type": "object",
          "required": ["npc_id", "held_by"],
          "additionalProperties": false,
          "properties": {
            "npc_id": { "type": "string" },
            "held_by": { "type": "integer" }
          }
        }
      }
    },
    {
      "type": "object",
      "required": ["kind", "body"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "move" },
        "body": {
          "type": "object",
          "required": ["position", "facing", "anim"],
          "additionalProperties": false,
          "properties": {
            "position": { "$ref": "#/$defs/vec2" },
            "facing": { "enum": ["up", "down", "left", "right"] },
            "anim": { "enum": ["idle", "walk"] }
          }
        }
      }
    },
    {
      "type": "object",
      "required": ["kind", "body"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "station" },
        "body": {
          "type": "object",
          "required": ["op", "station_id"],
          "additionalProperties": false,
          "properties": {
            "op": { "enum": ["occupy", "vacate"] },
            "station_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" }
          }
        }
      }
    },
    {
      "type": "object",
      "required": ["kind", "body"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "control" },
        "body": {
          "type": "object",
          "required": ["station_id", "axis", "value"],
          "additionalProperties": false,
          "properties": {
            "station_id": { "type": "string" },
            "axis": { "type": "string" },
            "value": {}
          }
        }
      }
    },
    {
      "type": "object",
      "required": ["kind", "body"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "choose" },
        "body": {
          "type": "object",
          "required": ["dialogue_id", "index"],
          "additionalProperties": false,
          "properties": {
            "dialogue_id": { "type": "string" },
            "index": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    {
      "type": "object",
      "required": ["kind", "body"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "say" },
        "body": {
          "type": "object",
          "required": ["text"],
          "additionalProperties": false,
          "properties": { "text": { "type": "string" } }
        }
      }
    },
    {
      "type": "object",
      "required": ["kind", "body"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "roster" },
        "body": {
          "type": "object",
          "required": ["players"],
          "additionalProperties": false,
          "properties": { "players": { "$ref": "#/$defs/roster" } }
        }
      }
    },
    {
      "type": "object",
      "required": ["kind", "body"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "seats" },
        "body": {
          "type": "object",
          "required": ["claimed"],
          "additionalProperties": false,
          "properties": { "claimed": { "$ref": "#/$defs/seats" } }
        }
      }
    },
    {
      "type": "object",
      "required": ["kind", "body"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "pawn" },
        "body": {
          "type": "object",
          "required": ["peer", "position", "facing", "anim"],
          "additionalProperties": false,
          "properties": {
            "peer": { "type": "integer" },
            "position": { "$ref": "#/$defs/vec2" },
            "facing": { "enum": ["up", "down", "left", "right"] },
            "anim": { "enum": ["idle", "walk"] }
          }
        }
      }
    },
    {
      "type": "object",
      "required": ["kind", "body"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "station_state" },
        "body": {
          "type": "object",
          "required": ["stations", "controls"],
          "additionalProperties": false,
          "properties": {
            "stations": { "type": "object" },
            "controls": { "type": "object" }
          }
        }
      }
    },
    {
      "type": "object",
      "required": ["kind", "body"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "dialogue_line" },
        "body": {
          "type": "object",
          "required": ["dialogue_id", "speaker", "text"],
          "additionalProperties": false,
          "properties": {
            "dialogue_id": { "type": "string" },
            "speaker": { "type": "string" },
            "text": { "type": "string" }
          }
        }
      }
    },
    {
      "type": "object",
      "required": ["kind", "body"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "dialogue_choices" },
        "body": {
          "type": "object",
          "required": ["dialogue_id", "choices"],
          "additionalProperties": false,
          "properties": {
            "dialogue_id": { "type": "string" },
            "choices": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["index", "text"],
                "additionalProperties": false,
                "properties": {
                  "index": { "type": "integer", "minimum": 0 },
                  "text": { "type": "string" }
                }
              }
            }
          }
        }
      }
    },
    {
      "type": "object",
      "required": ["kind", "body"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "dialogue_ended" },
        "body": {
          "type": "object",
          "required": ["dialogue_id"],
          "additionalProperties": false,
          "properties": { "dialogue_id": { "type": "string" } }
        }
      }
    },
    {
      "type": "object",
      "required": ["kind", "body"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "world" },
        "body": {
          "type": "object",
          "required": ["tick", "mode", "snapshot"],
          "additionalProperties": false,
          "properties": {
            "tick": { "type": "integer", "minimum": 0 },
            "mode": { "type": "string" },
            "snapshot": { "type": "object" }
          }
        }
      }
    }
  ],
  "$defs": {
    "vec2": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": { "type": "number" }
    },
    "roster": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["peer", "name", "npc_id"],
        "additionalProperties": false,
        "properties": {
          "peer": { "type": "integer" },
          "name": { "type": "string" },
          "npc_id": { "type": "string" }
        }
      }
    },
    "seats": {
      "type": "object",
      "additionalProperties": { "type": "integer" }
    }
  }
}
