{
  "$id": "reachlock://framework/v0/ship",
  "title": "Ship hull definition",
  "description": "A hull: class, chassis archetype, stats, hardpoints, interior rooms, and flight feel. GAME-DESIGN.md §3. All `flight` numbers are designer-facing units (units/s, rad/s) consumed directly by the flight model.",
  "type": "object",
  "required": [
    "id",
    "name",
    "class"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "name": {
      "type": "string"
    },
    "class": {
      "type": "string",
      "enum": [
        "shuttle",
        "corvette",
        "frigate",
        "destroyer",
        "freighter",
        "carrier",
        "station"
      ]
    },
    "chassis_archetype": {
      "type": "string",
      "enum": [
        "saucer",
        "rigid_frame",
        "military_doctrine",
        "modular"
      ]
    },
    "description": {
      "type": "string"
    },
    "origin": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "customization_tier": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "stats": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mass": {
          "type": "number",
          "minimum": 1
        },
        "armor": {
          "type": "integer",
          "minimum": 0
        },
        "crew_capacity": {
          "type": "integer",
          "minimum": 0
        },
        "cargo_capacity": {
          "type": "integer",
          "minimum": 0
        },
        "jump_drive_capable": {
          "type": "boolean"
        }
      }
    },
    "flight": {
      "type": "object",
      "description": "Flight feel. Engine defaults apply for anything omitted, so a hull with no flight block is still flyable.",
      "additionalProperties": false,
      "properties": {
        "top_speed": {
          "type": "number",
          "minimum": 1,
          "description": "Max cruise speed, units/s."
        },
        "acceleration": {
          "type": "number",
          "minimum": 1,
          "description": "How fast velocity approaches target, units/s^2."
        },
        "turn_rate": {
          "type": "number",
          "minimum": 0.1,
          "description": "Max pitch/yaw rate, rad/s."
        },
        "boost_multiplier": {
          "type": "number",
          "minimum": 1
        },
        "drift": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "0 = velocity snaps to the nose instantly (arcade-tight); 1 = pure Newtonian drift. Heavy haulers drift high, interceptors low."
        },
        "bank_angle_deg": {
          "type": "number",
          "minimum": 0,
          "maximum": 90
        }
      }
    },
    "hardpoints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "weapons": {
          "type": "integer",
          "minimum": 0
        },
        "utilities": {
          "type": "integer",
          "minimum": 0
        },
        "engines": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "interior_rooms": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]*$"
      },
      "description": "Deprecated — use `rooms` instead. List-only room ids for fallback grid."
    },
    "rooms": {
      "type": "array",
      "description": "Freeform positioned rooms. Each room has a position, size, color, optional doors, and optional station positions. A modder redesigns an interior by editing these rects — no engine code.",
      "items": {
        "type": "object",
        "required": [
          "id",
          "x",
          "y",
          "w",
          "h"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "name": {
            "type": "string"
          },
          "x": {
            "type": "number",
            "minimum": 0
          },
          "y": {
            "type": "number",
            "minimum": 0
          },
          "w": {
            "type": "number",
            "minimum": 60
          },
          "h": {
            "type": "number",
            "minimum": 60
          },
          "color": {
            "type": "string",
            "pattern": "^#[0-9a-fA-F]{6}$",
            "description": "Hex color override. Omitted = framework default per room kind."
          },
          "kind": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$",
            "description": "Room type (cockpit, bridge, engineering, etc.). Used for default colors and behavior."
          },
          "doors": {
            "type": "array",
            "description": "Door connections to other rooms. Each door renders as a gap in the wall.",
            "items": {
              "type": "object",
              "required": [
                "to"
              ],
              "additionalProperties": false,
              "properties": {
                "to": {
                  "type": "string",
                  "description": "Target room id."
                },
                "side": {
                  "type": "string",
                  "enum": [
                    "left",
                    "right",
                    "top",
                    "bottom"
                  ],
                  "description": "Side of the room the door opens onto. Omitted = auto-detect from overlapping edges."
                },
                "offset": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1,
                  "description": "Normalized position along the side (0=start, 1=end). 0.5=center."
                },
                "width": {
                  "type": "number",
                  "minimum": 16,
                  "maximum": 80,
                  "description": "Door opening width in pixels. Default 40."
                }
              }
            }
          },
          "stations": {
            "type": "array",
            "description": "Stations inside this room. Position is absolute pixel coords (not normalized).",
            "items": {
              "type": "object",
              "required": [
                "id"
              ],
              "additionalProperties": false,
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^[a-z][a-z0-9_]*$"
                },
                "name": {
                  "type": "string"
                },
                "x": {
                  "type": "number",
                  "description": "Absolute X position. Omitted = room center."
                },
                "y": {
                  "type": "number",
                  "description": "Absolute Y position. Omitted = room center."
                },
                "converts": {
                  "type": "object",
                  "required": [
                    "from",
                    "to"
                  ],
                  "additionalProperties": false,
                  "description": "This station refines cargo: `ratio` units of good `from` press into 1 unit of good `to` (a clean strike at the minigame; a jam grinds one unit to dust).",
                  "properties": {
                    "from": {
                      "type": "string"
                    },
                    "to": {
                      "type": "string"
                    },
                    "ratio": {
                      "type": "integer",
                      "minimum": 1,
                      "default": 2
                    }
                  }
                }
              }
            }
          },
          "props": {
            "type": "array",
            "description": "Furniture and set dressing: sprites placed in the room (assets/props/<sprite>.png via AssetLibrary). Purely visual unless a station shares the spot. `condition` is trigger-DSL — a prop can appear or vanish with story state (a wrecked bar).",
            "items": {
              "type": "object",
              "required": [
                "sprite",
                "x",
                "y"
              ],
              "additionalProperties": false,
              "properties": {
                "sprite": {
                  "type": "string",
                  "pattern": "^[a-z][a-z0-9_]*$"
                },
                "x": {
                  "type": "number"
                },
                "y": {
                  "type": "number"
                },
                "scale": {
                  "type": "number",
                  "minimum": 0.25
                },
                "condition": {
                  "type": "string",
                  "description": "Trigger-DSL guard; omitted = always shown."
                },
                "name": {
                  "type": "string"
                }
              }
            }
          },
          "deck": {
            "type": "string",
            "description": "Deck this room belongs to (a key of `decks`). Omitted = default deck."
          }
        }
      }
    },
    "room_zones": {
      "type": "object",
      "description": "Room ID -> hex color override for interior floor tiles. Defaults per room type apply when omitted.",
      "additionalProperties": {
        "type": "string",
        "pattern": "^#[0-9a-fA-F]{6}$"
      }
    },
    "stations": {
      "type": "array",
      "description": "Named stations in the ship interior. Each occupies a room. A modder adds a station by adding an entry here — no engine code.",
      "items": {
        "type": "object",
        "required": [
          "id",
          "room"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "name": {
            "type": "string"
          },
          "room": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "position": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "description": "Normalized position within the room rect. [0.5, 0.5] = center."
          }
        }
      }
    },
    "interior_layout": {
      "type": "object",
      "description": "Optional grid layout for the interior. Defines the rows/cols and room grid for proper spatial arrangement.",
      "additionalProperties": false,
      "properties": {
        "cols": {
          "type": "integer",
          "minimum": 1
        },
        "rows": {
          "type": "integer",
          "minimum": 1
        },
        "grid": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9_]*$"
            }
          }
        }
      }
    },
    "gravity": {
      "type": "object",
      "description": "Ship's artificial gravity system. Omitted = zero-G (magnetic boots or RCS required).",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "none",
            "magnetic_boots",
            "centrifugal",
            "energy_plate",
            "grav_plate"
          ]
        },
        "strength": {
          "type": "number",
          "minimum": 0,
          "maximum": 3,
          "default": 1.0
        },
        "power_draw": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.15
        },
        "safe": {
          "type": "boolean",
          "default": true
        },
        "augments": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z_]*$"
          }
        }
      }
    },
    "attached": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]*$"
      }
    },
    "extra": {
      "type": "object",
      "description": "Free-form escape hatch for mod-specific data. Never read by the engine."
    },
    "decks": {
      "type": "object",
      "description": "Named decks with independent gravity. Rooms opt in via their `deck` field (omitted = the hull default deck, 'lower' when decks exist). Each deck's gravity block overrides the hull `gravity` while the player walks that deck — a zero-G cargo level above a grav-plated crew level.",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string"
          },
          "order": {
            "type": "integer",
            "description": "Sort order for HUD display (higher = further up the hull)."
          },
          "gravity": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "none",
                  "magnetic_boots",
                  "centrifugal",
                  "energy_plate",
                  "grav_plate"
                ]
              },
              "strength": {
                "type": "number",
                "minimum": 0,
                "maximum": 3
              }
            }
          }
        }
      }
    },
    "ladders": {
      "type": "array",
      "description": "Ladders/hatches connecting decks. Each carries an interactable position per deck; using it moves the player to its position on the other deck.",
      "items": {
        "type": "object",
        "required": [
          "positions"
        ],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string"
          },
          "positions": {
            "type": "object",
            "minProperties": 2,
            "additionalProperties": {
              "type": "array",
              "minItems": 2,
              "maxItems": 2,
              "items": {
                "type": "number"
              }
            },
            "description": "deck id → [x, y] of the ladder on that deck."
          }
        }
      }
    }
  }
}
