{
  "$id": "reachlock://framework/v0/weave_proposal",
  "title": "Weave proposal",
  "description": "What a mind returns for a `woven` dialogue node: a line, optional world effects, optional player choices (WEAVE-CONTRACT.md). This is a PROPOSAL — the engine validates every mutation against the node's `may` allowlist and clamps or drops anything outside it before the branch becomes real. The mutation vocabulary mirrors dialogue.schema.json exactly and never extends it.",
  "type": "object",
  "required": ["line"],
  "additionalProperties": false,
  "properties": {
    "line": {
      "type": "string",
      "minLength": 1
    },
    "mutations": {
      "type": "array",
      "items": { "$ref": "#/$defs/mutation" }
    },
    "choices": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["text"],
        "additionalProperties": false,
        "properties": {
          "text": { "type": "string", "minLength": 1 },
          "mutations": {
            "type": "array",
            "items": { "$ref": "#/$defs/mutation" }
          }
        }
      }
    }
  },
  "$defs": {
    "mutation": {
      "oneOf": [
        {
          "type": "object",
          "required": ["op", "target", "axis", "amount"],
          "additionalProperties": false,
          "properties": {
            "op": { "const": "adjust_relationship" },
            "target": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
            "axis": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
            "amount": { "type": "integer", "minimum": -100, "maximum": 100 }
          }
        },
        {
          "type": "object",
          "required": ["op", "text"],
          "additionalProperties": false,
          "properties": {
            "op": { "const": "add_memory" },
            "text": { "type": "string" },
            "importance": { "type": "number", "minimum": 0, "maximum": 1 },
            "tags": { "type": "array", "items": { "type": "string" } }
          }
        },
        {
          "type": "object",
          "required": ["op", "flag"],
          "additionalProperties": false,
          "properties": {
            "op": { "enum": ["set_flag", "clear_flag", "set_player_flag", "clear_player_flag"] },
            "flag": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" }
          }
        },
        {
          "type": "object",
          "required": ["op", "faction", "axis", "amount"],
          "additionalProperties": false,
          "properties": {
            "op": { "const": "adjust_faction" },
            "faction": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
            "axis": { "enum": ["trust", "contribution", "notoriety"] },
            "amount": { "type": "integer", "minimum": -100, "maximum": 100 }
          }
        }
      ]
    }
  }
}
