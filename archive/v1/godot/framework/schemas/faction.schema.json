{
  "$id": "reachlock://framework/v0/faction",
  "title": "Faction definition",
  "description": "A faction: territory, resources, relationships, internal divisions, goals. GAME-DESIGN.md §5. Relationship stances are framework vocabulary consumed by the faction simulator.",
  "type": "object",
  "required": ["id", "name"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
    "name": { "type": "string" },
    "short_name": { "type": "string" },
    "description": { "type": "string" },
    "territory": { "type": "array", "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" } },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "produces": { "type": "array", "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" } },
        "consumes": { "type": "array", "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" } }
      }
    },
    "relationships": {
      "type": "object",
      "description": "Other faction id -> default stance at universe start. The simulator owns the live value from there.",
      "additionalProperties": {
        "type": "string",
        "enum": ["allied", "friendly", "neutral", "tense", "hostile", "war"]
      }
    },
    "internal_divisions": { "type": "array", "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" } },
    "goals": { "type": "array", "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" } },
    "extra": { "type": "object", "description": "Free-form escape hatch for mod-specific data. Never read by the engine." }
  }
}
